# Google OAuth 2.0 Client Credentials for Career Upskiller
# 1. Copy this file to '.env': cp .env.example .env
# 2. Fill in the client ID and client secret you generate from Google Cloud Console.

GOOGLE_CLIENT_ID="YOUR_CLIENT_ID_HERE.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_CLIENT_SECRET_HERE"

# The redirect URI used by the frontend callback page.
# If running locally, keep this as http://localhost:5173/oauth-callback
GOOGLE_REDIRECT_URI="http://localhost:5173/oauth-callback"

# Google Cloud Project ID
# This prevents the backend from dynamically searching through your Google Cloud accounts.
GOOGLE_CLOUD_PROJECT="YOUR_GOOGLE_CLOUD_PROJECT_ID_HERE"

